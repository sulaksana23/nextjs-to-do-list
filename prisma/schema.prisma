generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TodoTaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TodoTaskStatus {
  HOLD
  IN_PROGRESS
  DONE
}

enum TodoUserRole {
  SUPERADMINISTRATOR
  ADMINISTRATOR
  MEMBER
}

enum TodoPermission {
  MANAGE_COMPANY_SETTINGS
  MANAGE_USERS
  MANAGE_ROLES
  MANAGE_PROJECTS
  MANAGE_TASKS
  VIEW_REPORTS
  MANAGE_NOTIFICATIONS
}

model TodoCompany {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  roles     TodoRole[]
  users     TodoUser[]
  projects  TodoProject[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("todo_companies")
}

model TodoRole {
  id          String           @id @default(cuid())
  companyId   String
  company     TodoCompany      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  baseRole    TodoUserRole     @default(MEMBER)
  permissions TodoPermission[]
  isSystem    Boolean          @default(false)
  users       TodoUser[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([companyId, slug])
  @@index([companyId])
  @@map("todo_roles")
}

model TodoUser {
  id                 String         @id @default(cuid())
  companyId          String
  company            TodoCompany    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  roleId             String?
  workspaceRole      TodoRole?      @relation(fields: [roleId], references: [id], onDelete: SetNull)
  name               String
  initials           String
  color              String
  role               TodoUserRole   @default(MEMBER)
  telegramNumber     String?        @unique
  telegramChatId     String?
  telegramConnectCode String?       @unique
  passwordHash       String?
  tasks              TodoTask[]
  assignedSubtasks   TodoSubtask[]  @relation("TodoSubtaskAssignee")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([companyId])
  @@index([roleId])
  @@map("todo_users")
}

model TodoProject {
  id        String      @id @default(cuid())
  companyId String
  company   TodoCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  tasks     TodoTask[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([companyId, slug])
  @@index([companyId])
  @@map("todo_projects")
}

model TodoTask {
  id          String           @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  deadlineReminderSentAt DateTime?
  priority    TodoTaskPriority @default(MEDIUM)
  category    String
  projectId   String
  project     TodoProject      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  status      TodoTaskStatus   @default(IN_PROGRESS)
  assigneeId  String?
  assignee    TodoUser?        @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  subtasks    TodoSubtask[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status])
  @@index([assigneeId])
  @@index([dueDate])
  @@index([projectId])
  @@map("todo_tasks")
}

model TodoSubtask {
  id         String    @id @default(cuid())
  title      String
  completed  Boolean   @default(false)
  position   Int       @default(0)
  taskId     String
  task       TodoTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assigneeId String?
  assignee   TodoUser? @relation("TodoSubtaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([taskId, position])
  @@index([assigneeId])
  @@map("todo_subtasks")
}
